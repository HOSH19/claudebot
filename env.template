# env.template
#
# This file documents which env vars the wrapper scripts need.
# In CURSOR AUTOMATIONS / CLOUD AGENTS: do NOT use this file.
#   Set these as Secrets at https://cursor.com/dashboard/cloud-agents
#   (mark sensitive ones as redacted) so they are injected into the VM.
#
# In LOCAL mode (optional): copy to .env and fill in. .env is gitignored.

# Alpaca — start with PAPER, flip to live once confident
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Perplexity (research)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar

# ClickUp (notifications — posts to a Chat channel, NOT a task)
CLICKUP_API_KEY=your_clickup_api_key_here
CLICKUP_WORKSPACE_ID=your_clickup_workspace_id_here
CLICKUP_CHANNEL_ID=your_clickup_channel_id_here
